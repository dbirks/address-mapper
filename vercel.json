{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && pnpm install && pnpm build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/upload-image", "destination": "/api/upload_image.py" },
    { "source": "/api/health", "destination": "/api/upload_image.py" }
  ],
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python"
    }
  }
}