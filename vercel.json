{
  "buildCommand": "cd ui && pnpm install && pnpm exec vite build && cd ../api && uv pip install -e .",
  "outputDirectory": "ui/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/main.py" }
  ],
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@3.1.0"
    }
  }
}